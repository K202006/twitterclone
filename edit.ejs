<%- include('partials/header') %>

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h4 class="card-title mb-4 fw-bold">Edit Tweet</h4>
                <form action="/tweets/<%= tweet._id %>?_method=PUT" method="POST">
                    <div class="mb-3">
                        <label class="form-label text-muted fw-bold">@<%= tweet.username %></label>
                        <textarea class="form-control fs-5 bg-light" name="tweetContent" rows="4" required><%= tweet.tweetContent %></textarea>
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a href="/tweets" class="btn btn-outline-secondary px-4">Cancel</a>
                        <button type="submit" class="btn btn-success px-4 fw-bold">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
